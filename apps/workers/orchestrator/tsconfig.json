{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "types": ["@cloudflare/workers-types"],
    "paths": {
      "@watchllm/types": ["../../../packages/types/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts"]
}
